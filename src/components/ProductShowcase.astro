---
import { products } from '../data/products';
const base = import.meta.env.BASE_URL;
---

<section id="products" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold text-primary-400 sm:text-4xl">
        Our Products
      </h2>
      <p class="mt-4 text-text-secondary">
        Purpose-built modules that extend Ignition's messaging capabilities.
      </p>
    </div>
    <div class="mx-auto flex max-w-4xl flex-wrap justify-center gap-6">
      {products.map((product) => (
        <a
          href={`${base}products/${product.slug}`}
          class="group w-full max-w-sm rounded-xl border border-surface-700/50 bg-surface-800/50 p-8 transition-all hover:border-primary-500/30 hover:bg-surface-800"
        >
          <img src={`${base}${product.fullLogo.replace(/^\//, '')}`} alt={product.name} class="mb-5 h-9" />
          <p class="mb-3 text-sm font-medium text-accent-400">{product.tagline}</p>
          <p class="text-sm leading-relaxed text-text-secondary">{product.description}</p>
          <span class="mt-5 inline-flex items-center text-sm font-medium text-primary-400 transition-colors group-hover:text-primary-300">
            Learn more
            <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
