---
import { products } from '../data/products';
const base = import.meta.env.BASE_URL;

const productItems = products.map((p) => ({
  label: p.name,
  href: `${base}products/${p.slug}`,
  description: p.name,
  logo: `${base}${p.logo.replace(/^\//, '')}`,
}));

const topLinks = [
  { label: 'About', href: `${base}about` },
  { label: 'Contact', href: 'mailto:contact@nexwavetechnologies.com' },
];
---

<header class="sticky top-0 z-50 border-b border-surface-700/50 bg-surface-950/80 backdrop-blur-lg">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Compact Logo: Wave mark + wordmark -->
    <a href={base} class="flex items-center gap-2.5">
      <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none">
        <path d="M4 10Q10 4 16 10Q22 16 28 10" stroke="#3b82f6" stroke-width="3" stroke-linecap="round" fill="none"/>
        <path d="M4 16Q10 10 16 16Q22 22 28 16" stroke="#34d399" stroke-width="3" stroke-linecap="round" fill="none"/>
        <path d="M4 22Q10 16 16 22Q22 28 28 22" stroke="#3b82f6" stroke-width="3" stroke-linecap="round" fill="none" opacity="0.4"/>
      </svg>
      <span class="font-display text-xl text-text-primary">
        <span class="font-bold">Nex</span><span class="font-light">Wave</span>
        <span class="font-light text-text-muted"> Technologies</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden items-center gap-8 md:flex">
      <!-- Products Dropdown -->
      <li class="relative" id="desktop-dropdown">
        <button
          class="flex items-center gap-1 text-sm text-text-secondary transition-colors hover:text-primary-400"
          id="desktop-products-btn"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Products
          <svg class="h-4 w-4 transition-transform" id="desktop-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          id="desktop-dropdown-panel"
          class="invisible absolute left-1/2 top-full z-50 mt-3 w-72 -translate-x-1/2 rounded-xl border border-surface-700/50 bg-surface-900/95 p-2 opacity-0 shadow-xl backdrop-blur-lg transition-all duration-200"
        >
          {productItems.map((item) => (
            <a
              href={item.href}
              class="flex items-center gap-3 rounded-lg px-3 py-3 transition-colors hover:bg-surface-800"
            >
              <img src={item.logo} alt={item.label} class="h-6 w-6 shrink-0" />
              <span class="block text-xs text-text-muted">{item.description}</span>
            </a>
          ))}
        </div>
      </li>

      <!-- Top-level links -->
      {topLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-text-secondary transition-colors hover:text-primary-400"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-text-secondary transition-transform" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-text-secondary transition-opacity" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-text-secondary transition-transform" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden border-t border-surface-700/50 md:hidden">
    <ul class="mx-auto max-w-7xl space-y-1 px-4 py-4">
      <!-- Products Accordion -->
      <li>
        <button
          class="flex w-full items-center justify-between rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-800 hover:text-primary-400"
          id="mobile-products-toggle"
          aria-expanded="false"
        >
          Products
          <svg class="h-4 w-4 transition-transform" id="mobile-products-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <ul id="mobile-products-submenu" class="ml-4 mt-1 hidden space-y-1">
          {productItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="mobile-nav-link block rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-800 hover:text-primary-400"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </li>

      <!-- Top-level links -->
      {topLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block rounded-lg px-3 py-2 text-sm text-text-secondary transition-colors hover:bg-surface-800 hover:text-primary-400"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // ── Mobile menu toggle ──
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    bar1?.classList.toggle('translate-y-[4px]', isOpen);
    bar1?.classList.toggle('rotate-45', isOpen);
    bar2?.classList.toggle('opacity-0', isOpen);
    bar3?.classList.toggle('-translate-y-[4px]', isOpen);
    bar3?.classList.toggle('-rotate-45', isOpen);
  });

  // Close mobile menu when a link is clicked
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      bar1?.classList.remove('translate-y-[4px]', 'rotate-45');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-translate-y-[4px]', '-rotate-45');
    });
  });

  // ── Mobile products accordion ──
  const mobileToggle = document.getElementById('mobile-products-toggle');
  const mobileSubmenu = document.getElementById('mobile-products-submenu');
  const mobileChevron = document.getElementById('mobile-products-chevron');

  mobileToggle?.addEventListener('click', () => {
    const isOpen = mobileSubmenu?.classList.toggle('hidden') === false;
    mobileToggle.setAttribute('aria-expanded', String(isOpen));
    mobileChevron?.classList.toggle('rotate-180', isOpen);
  });

  // ── Desktop products dropdown ──
  const desktopBtn = document.getElementById('desktop-products-btn');
  const desktopPanel = document.getElementById('desktop-dropdown-panel');
  const desktopChevron = document.getElementById('desktop-chevron');
  const desktopDropdown = document.getElementById('desktop-dropdown');
  let desktopOpen = false;

  function openDesktopDropdown() {
    desktopPanel?.classList.remove('invisible', 'opacity-0');
    desktopPanel?.classList.add('visible', 'opacity-100');
    desktopChevron?.classList.add('rotate-180');
    desktopBtn?.setAttribute('aria-expanded', 'true');
    desktopOpen = true;
  }

  function closeDesktopDropdown() {
    desktopPanel?.classList.add('invisible', 'opacity-0');
    desktopPanel?.classList.remove('visible', 'opacity-100');
    desktopChevron?.classList.remove('rotate-180');
    desktopBtn?.setAttribute('aria-expanded', 'false');
    desktopOpen = false;
  }

  // Toggle on click
  desktopBtn?.addEventListener('click', () => {
    desktopOpen ? closeDesktopDropdown() : openDesktopDropdown();
  });

  // Open on hover
  desktopDropdown?.addEventListener('mouseenter', openDesktopDropdown);
  desktopDropdown?.addEventListener('mouseleave', closeDesktopDropdown);

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (desktopOpen && !desktopDropdown?.contains(e.target as Node)) {
      closeDesktopDropdown();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && desktopOpen) {
      closeDesktopDropdown();
      desktopBtn?.focus();
    }
  });
</script>
