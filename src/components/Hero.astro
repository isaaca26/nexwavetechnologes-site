---
const base = import.meta.env.BASE_URL;
---

<section id="hero" class="relative overflow-hidden py-20 sm:py-28 lg:py-36">
  <!-- Background gradient effect -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-600/10 blur-[120px]"></div>
    <div class="absolute right-0 top-1/2 h-[400px] w-[400px] -translate-y-1/2 rounded-full bg-accent-500/8 blur-[100px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Product Logo -->
      <img src={`${base}logos/nexstream-full-dark.svg`} alt="NexStream for NATS" class="mx-auto mb-8 h-12 sm:h-14" />

      <h1 class="font-display text-4xl font-bold tracking-tight text-text-primary sm:text-5xl lg:text-6xl">
        Bridge Ignition to NATS
        <span class="bg-gradient-to-r from-primary-400 to-accent-400 bg-clip-text text-transparent">
          — Seamlessly
        </span>
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-text-secondary sm:text-xl">
        NexStream for NATS brings native NATS and JetStream messaging to Ignition Event Streams.
        Publish, subscribe, and stream industrial data with the reliability and speed
        your operations demand.
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="#pricing"
          class="inline-flex items-center rounded-lg bg-primary-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-600/25 transition-all hover:bg-primary-500 hover:shadow-primary-500/30"
        >
          Get on Module Showcase
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="#cta"
          class="inline-flex items-center rounded-lg border border-surface-600 px-6 py-3 text-sm font-semibold text-text-primary transition-all hover:border-primary-500/50 hover:bg-surface-800"
        >
          Contact Us
        </a>
      </div>
    </div>
  </div>
</section>
